# Saltire loyalty + referral — example values. Copy to .env and fill in.

# ─── GHL API ──────────────────────────────────────────────────────────────────
GHL_API_TOKEN=
GHL_LOCATION_ID=
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# ─── Custom field IDs — Loyalty ───────────────────────────────────────────────
GHL_FIELD_STAMP_COUNT=
GHL_FIELD_LIFETIME_VISITS=
GHL_FIELD_FIRST_VISIT_DATE=
GHL_FIELD_LAST_VISIT_DATE=
GHL_FIELD_LAST_SCAN_TIMESTAMP=
GHL_FIELD_PERSONAL_QR_URL=
GHL_FIELD_REFERRAL_CODE=
GHL_FIELD_REFERRED_BY=
GHL_FIELD_REWARDS_REDEEMED=
GHL_FIELD_LAST_REWARD_ISSUED=

# ─── Custom field IDs — Auth ──────────────────────────────────────────────────
GHL_FIELD_PASSWORD_HASH=

# ─── Custom field IDs — Family ────────────────────────────────────────────────
GHL_FIELD_FAMILY_LINKED_ID=

# ─── Custom field IDs — Children (up to 4) ────────────────────────────────────
GHL_FIELD_CHILD_1_NAME=
GHL_FIELD_CHILD_1_DOB=
GHL_FIELD_CHILD_2_NAME=
GHL_FIELD_CHILD_2_DOB=
GHL_FIELD_CHILD_3_NAME=
GHL_FIELD_CHILD_3_DOB=
GHL_FIELD_CHILD_4_NAME=
GHL_FIELD_CHILD_4_DOB=

# ─── Custom field IDs — Party booking ────────────────────────────────────────
GHL_FIELD_PARTY_DATE=
GHL_FIELD_PARTY_PACKAGE=
GHL_FIELD_PARTY_GUEST_COUNT=
GHL_FIELD_PARTY_NOTES=

# ─── Loyalty rules ────────────────────────────────────────────────────────────
STAMPS_REQUIRED_FOR_REWARD=8
SCAN_COOLDOWN_HOURS=8

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Staff scanner ────────────────────────────────────────────────────────────
STAFF_SCANNER_PIN=

# ─── QR generation ────────────────────────────────────────────────────────────
QR_GENERATOR_BASE_URL=https://api.qrserver.com/v1/create-qr-code/
SITE_BASE_URL=https://www.saltirecentre.co.uk

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
